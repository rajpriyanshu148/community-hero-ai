# =============================================================================
# Community Hero AI - Backend Environment Variables
# Copy this file to .env and fill in all values
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=5000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database - PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/community_hero_ai

# -----------------------------------------------------------------------------
# Authentication - JWT Secrets (use at least 64 character random strings)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=your_jwt_secret_here_minimum_64_characters_long_for_security
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_minimum_64_characters_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Google OAuth 2.0
# Get credentials from: https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# -----------------------------------------------------------------------------
# Redis - Cache and Session Store
# Default: redis://localhost:6379
# For Redis Cloud: rediss://default:password@host:port
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Google Gemini AI
# Get from: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# Google Maps Platform
# Get from: https://console.cloud.google.com/apis/credentials
# Required APIs: Maps JavaScript API, Geocoding API, Places API
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# -----------------------------------------------------------------------------
# OpenWeatherMap API
# Get from: https://openweathermap.org/api
# Free tier: 1000 calls/day, One Call API 3.0
# -----------------------------------------------------------------------------
OPENWEATHER_API_KEY=your_openweather_api_key_here

# -----------------------------------------------------------------------------
# Frontend URL - For CORS and redirect configuration
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# File Upload Configuration
# UPLOAD_DIR: Directory where uploaded files will be stored (relative to project root)
# MAX_FILE_SIZE: Maximum file size in bytes (default: 10MB = 10485760)
# -----------------------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# -----------------------------------------------------------------------------
# Session Secret - Used for express-session (Google OAuth flow)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
SESSION_SECRET=your_session_secret_here_at_least_32_characters

# -----------------------------------------------------------------------------
# Error Tracking - Sentry (Optional)
# Get from: https://sentry.io
# Leave empty to disable Sentry
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Analytics - PostHog (Optional)
# Get from: https://posthog.com
# Leave empty to disable PostHog
# -----------------------------------------------------------------------------
POSTHOG_KEY=

# -----------------------------------------------------------------------------
# Optional: Cloudinary (for production media storage)
# If set, media uploads will use Cloudinary instead of local disk
# Get from: https://cloudinary.com/console
# -----------------------------------------------------------------------------
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
